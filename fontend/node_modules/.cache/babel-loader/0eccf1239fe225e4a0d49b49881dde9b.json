llName","CompanyName","DateOfBirth","JobTitle","Signup"],"sources":["src/login/Signup_3.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <div class=\"page-login\" v-if=\"!showSignup_2\">\r\n            <div class=\"box-login\">\r\n                <div class=\"title-login\">\r\n                    <img src=\"../assets/icon/sidebar/logo-2.png\" width=\"100\" height=\"100\" alt=\"\">\r\n                    <div style=\"margin-top: 20px\">\r\n                        DataLink\r\n                    </div>\r\n                </div>\r\n                <form action=\"\">\r\n                    <div class=\"line-input\">\r\n                        <label for=\"\" class=\"label-input\">Nhập họ và tên</label>\r\n                        <cc-input v-model=\"username\" :placeholderInput=\"placeholderName\" />\r\n                        <div v-if=\"errorName\" class=\"error-message\">{{ errorName }}</div>\r\n                    </div>\r\n                    <div class=\"line-input\">\r\n                        <label for=\"\" class=\"label-input\">Ngày sinh</label>\r\n                        <input type=\"date\" v-model=\"dateOfBirth\" class=\"input-date\" />\r\n                        <div v-if=\"errorDateOfBirth\" class=\"error-message\">{{ errorDateOfBirth }}</div>\r\n                    </div>\r\n                    <div class=\"line-input\">\r\n                        <label for=\"\" class=\"label-input\">Tên công ty</label>\r\n                        <cc-input v-model=\"companyName\" :placeholderInput=\"placeholderCompany\" />\r\n                        <div v-if=\"errorCompany\" class=\"error-message\">{{ errorCompany }}</div>\r\n                    </div>\r\n                    <div class=\"line-input\">\r\n                        <label for=\"\" class=\"label-input\">Số điện thoại</label>\r\n                        <cc-input v-model=\"phoneNumber\" :placeholderInput=\"placeholderPhone\" />\r\n                        <div v-if=\"errorPhone\" class=\"error-message\">{{ errorPhone }}</div>\r\n                    </div>\r\n                    <div class=\"line-input\">\r\n                        <label for=\"\" class=\"label-input\">Chức vụ</label>\r\n                        <cc-input v-model=\"jobTitle\" :placeholderInput=\"placeholderJob\" />\r\n                        <div v-if=\"errorJob\" class=\"error-message\">{{ errorJob }}</div>\r\n                    </div>\r\n                    <div class=\"line-tool\">\r\n                        <div class=\"item-tool\"><RouterLink to=\"/login\">Đăng nhập</RouterLink></div>\r\n                    </div>\r\n                    <div class=\"line-submit\">\r\n                        <button class=\"btn-common-primary\" @click=\"signup\">Hoàn tất đăng ký</button>\r\n                    </div>\r\n                </form>\r\n            </div>\r\n        </div>\r\n        <signup_3 v-if=\"showSignup_3\" />\r\n    </div>\r\n</template>\r\n<script>\r\nimport ccInput from '../components/input/ccInput.vue'\r\nimport UserAPI from '../api/Components/UserAPI'\r\nexport default {\r\n    components: { ccInput },\r\n    data() {\r\n        return {\r\n            placeholderName:\"Họ và tên\",\r\n            username: \"\",\r\n            errorName: \"\",  \r\n            dateOfBirth: \"\",\r\n            errorDateOfBirth: \"\",\r\n            companyName: \"\",\r\n            errorCompany: \"\",\r\n            phoneNumber: \"\",\r\n            errorPhone: \"\",\r\n            jobTitle: \"\",\r\n            errorJob: \"\",\r\n            placeholderCompany: \"Tên công ty\",\r\n            placeholderJob: \"Chức vụ\",\r\n            placeholderPhone: \"Số điện thoại\"\r\n        }\r\n    },\r\n    methods: {\r\n        validateName() {\r\n            if (!this.username) {\r\n                this.errorName = \"Vui lòng nhập họ và tên\";\r\n                return false;\r\n            }\r\n            if (this.username.length < 2) {\r\n                this.errorName = \"Họ và tên phải có ít nhất 2 ký tự\";\r\n                return false;\r\n            }\r\n            this.errorName = \"\";\r\n            return true;\r\n        },\r\n        validateCompany() {\r\n            if (!this.companyName) {\r\n                this.errorCompany = \"Vui lòng nhập tên công ty\";\r\n                return false;\r\n            }\r\n            if (this.companyName.length < 2) {\r\n                this.errorCompany = \"Tên công ty phải có ít nhất 2 ký tự\";\r\n                return false;\r\n            }\r\n            this.errorCompany = \"\";\r\n            return true;\r\n        },\r\n        validatePhone() {\r\n            if (!this.phoneNumber) {\r\n                this.errorPhone = \"Vui lòng nhập số điện thoại\";\r\n                return false;\r\n            }\r\n            \r\n            // Loại bỏ khoảng trắng và dấu gạch ngang nếu có\r\n            const cleanPhone = this.phoneNumber.replace(/[\\s-]/g, '');\r\n            \r\n            // Kiểm tra định dạng số điện thoại Việt Nam\r\n            // Format 1: Bắt đầu bằng 0 và có 10 số\r\n            // Format 2: Bắt đầu bằng 84 và có 11 số\r\n            const phoneRegex = /^(0[3|5|7|8|9][0-9]{8}|84[3|5|7|8|9][0-9]{8})$/;\r\n            \r\n            if (!phoneRegex.test(cleanPhone)) {\r\n                this.errorPhone = \"Số điện thoại không hợp lệ. Phải bắt đầu bằng 0 (10 số) hoặc 84 (11 số)\";\r\n                return false;\r\n            }\r\n            \r\n            this.errorPhone = \"\";\r\n            return true;\r\n        },\r\n        validateAge() {\r\n            if (!this.dateOfBirth) {\r\n                this.errorDateOfBirth = \"Vui lòng chọn ngày sinh\";\r\n                return false;\r\n            }\r\n            \r\n            const today = new Date();\r\n            const birthDate = new Date(this.dateOfBirth);\r\n            let age = today.getFullYear() - birthDate.getFullYear();\r\n            const monthDiff = today.getMonth() - birthDate.getMonth();\r\n            \r\n            if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {\r\n                age--;\r\n            }\r\n            \r\n            if (age < 16) {\r\n                this.errorDateOfBirth = \"Bạn phải đủ 16 tuổi để đăng ký\";\r\n                return false;\r\n            }\r\n            \r\n            this.errorDateOfBirth = \"\";\r\n            return true;\r\n        },\r\n        validateForm() {\r\n            const isNameValid = this.validateName();\r\n            const isCompanyValid = this.validateCompany();\r\n            const isPhoneValid = this.validatePhone();\r\n            const isAgeValid = this.validateAge();\r\n            \r\n            return isNameValid && isCompanyValid && isPhoneValid && isAgeValid;\r\n        },\r\n        signup() {\r\n            if (this.validateForm()) {\r\n                var param = {\r\n                    Username: this.$store.getters.username,\r\n                    Password: this.$store.getters.password,\r\n                    PhoneNumber: this.phoneNumber,\r\n                    FullName: this.username,\r\n                    CompanyName: this.companyName,\r\n                    DateOfBirth: this.dateOfBirth,\r\n                    JobTitle: this.jobTitle\r\n                }\r\n                UserAPI.Signup(param);\r\n            }\r\n        }\r\n    },\r\n}\r\n</script>\r\n<style lang=\"scss\" scoped>\r\n.page-login {\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n    width: 100vw;\r\n    height: 100vh;\r\n    background-image: url('../assets/image/banner1.jpg');\r\n    background-size: cover;\r\n}\r\n    .box-login {\r\n        display: flex;\r\n        flex-direction: column;\r\n        width: 450px;\r\n        background-color: #ffffff;\r\n        border-radius: 10px;\r\n        padding: 25px;\r\n    }\r\n        .title-login {\r\n            width: 100%;\r\n            text-align: center;\r\n            font-weight: 700;\r\n            font-size: 3rem/* 48px */;\r\n            line-height: 1;\r\n            color: #2962FF;\r\n            margin-bottom: 2rem;\r\n        }\r\n        .line-input {\r\n            display: flex;\r\n            margin-top: 1.25rem/* 20px */;\r\n            margin-bottom: 1.25rem/* 20px */;\r\n            flex-direction: column;\r\n        }\r\n        .line-tool {\r\n            display: flex;\r\n            flex-direction: row;\r\n            justify-content: space-between;\r\n            margin-top: 0.5rem/* 8px */;\r\n            margin-bottom: 0.5rem/* 8px */;\r\n        }\r\n            .label-input {\r\n                margin-bottom: 10px;\r\n            } \r\n            .item-tool {\r\n                text-decoration: underline;\r\n                font-style: italic;\r\n                cursor: pointer;\r\n            }\r\n        .line-submit {\r\n            display: flex;\r\n            margin-top: 2.5rem/* 40px */;\r\n            margin-bottom: 2.5rem/* 40px */;\r\n            justify-content: center;\r\n        }\r\n        .btn-common-primary {\r\n            position: relative;\r\n            height: 36px;\r\n            padding: 0 16px;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center; \r\n            border-radius: 4px;\r\n            font-size: 14px;\r\n            font-weight: 500;\r\n            outline: none;\r\n            min-width: 80px;\r\n            width: 100%;\r\n            cursor: pointer;\r\n            color: #ffffff;\r\n            background-color: #2962FF;\r\n            border: none;\r\n            &:hover{\r\n                background-color: #2979FF;\r\n            }\r\n            &:active{\r\n                background-color: #304FFE;\r\n            }\r\n        }\r\n        .error-message {\r\n            color: #ff4d4f;\r\n            font-size: 12px;\r\n            margin-top: 4px;\r\n        }\r\n        .input-date {\r\n            height: 36px;\r\n            padding: 0 12px;\r\n            border: 1px solid #d9d9d9;\r\n            border-radius: 4px;\r\n            width: 100%;\r\n            font-size: 14px;\r\n            &:focus {\r\n                outline: none;\r\n                border-color: #2962FF;\r\n            }\r\n        }\r\n</style>"],"mappings":"AAiDA,OAAAA,OAAA;AACA,OAAAC,OAAA;AACA;EACAC,UAAA;IAAAF;EAAA;EACAG,KAAA;IACA;MACAC,eAAA;MACAC,QAAA;MACAC,SAAA;MACAC,WAAA;MACAC,gBAAA;MACAC,WAAA;MACAC,YAAA;MACAC,WAAA;MACAC,UAAA;MACAC,QAAA;MACAC,QAAA;MACAC,kBAAA;MACAC,cAAA;MACAC,gBAAA;IACA;EACA;EACAC,OAAA;IACAC,aAAA;MACA,UAAAd,QAAA;QACA,KAAAC,SAAA;QACA;MACA;MACA,SAAAD,QAAA,CAAAe,MAAA;QACA,KAAAd,SAAA;QACA;MACA;MACA,KAAAA,SAAA;MACA;IACA;IACAe,gBAAA;MACA,UAAAZ,WAAA;QACA,KAAAC,YAAA;QACA;MACA;MACA,SAAAD,WAAA,CAAAW,MAAA;QACA,KAAAV,YAAA;QACA;MACA;MACA,KAAAA,YAAA;MACA;IACA;IACAY,cAAA;MACA,UAAAX,WAAA;QACA,KAAAC,UAAA;QACA;MACA;;MAEA;MACA,MAAAW,UAAA,QAAAZ,WAAA,CAAAa,OAAA;;MAEA;MACA;MACA;MACA,MAAAC,UAAA;MAEA,KAAAA,UAAA,CAAAC,IAAA,CAAAH,UAAA;QACA,KAAAX,UAAA;QACA;MACA;MAEA,KAAAA,UAAA;MACA;IACA;IACAe,YAAA;MACA,UAAApB,WAAA;QACA,KAAAC,gBAAA;QACA;MACA;MAEA,MAAAoB,KAAA,OAAAC,IAAA;MACA,MAAAC,SAAA,OAAAD,IAAA,MAAAtB,WAAA;MACA,IAAAwB,GAAA,GAAAH,KAAA,CAAAI,WAAA,KAAAF,SAAA,CAAAE,WAAA;MACA,MAAAC,SAAA,GAAAL,KAAA,CAAAM,QAAA,KAAAJ,SAAA,CAAAI,QAAA;MAEA,IAAAD,SAAA,QAAAA,SAAA,UAAAL,KAAA,CAAAO,OAAA,KAAAL,SAAA,CAAAK,OAAA;QACAJ,GAAA;MACA;MAEA,IAAAA,GAAA;QACA,KAAAvB,gBAAA;QACA;MACA;MAEA,KAAAA,gBAAA;MACA;IACA;IACA4B,aAAA;MACA,MAAAC,WAAA,QAAAlB,YAAA;MACA,MAAAmB,cAAA,QAAAjB,eAAA;MACA,MAAAkB,YAAA,QAAAjB,aAAA;MACA,MAAAkB,UAAA,QAAAb,WAAA;MAEA,OAAAU,WAAA,IAAAC,cAAA,IAAAC,YAAA,IAAAC,UAAA;IACA;IACAC,OAAA;MACA,SAAAL,YAAA;QACA,IAAAM,KAAA;UACAC,QAAA,OAAAC,MAAA,CAAAC,OAAA,CAAAxC,QAAA;UACAyC,QAAA,OAAAF,MAAA,CAAAC,OAAA,CAAAE,QAAA;UACAC,WAAA,OAAArC,WAAA;UACAsC,QAAA,OAAA5C,QAAA;UACA6C,WAAA,OAAAzC,WAAA;UACA0C,WAAA,OAAA5C,WAAA;UACA6C,QAAA,OAAAvC;QACA;QACAZ,OAAA,CAAAoD,MAAA,CAAAX,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]}]}