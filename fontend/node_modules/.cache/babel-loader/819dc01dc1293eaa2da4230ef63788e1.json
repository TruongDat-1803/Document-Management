e\" :loading=\"loading\">\n                    Tải lên\n                </cc-button>\n            </div>\n        </cc-popup>\n    </div>\n</template>\n<script>\nimport FileAPI from '@/api/Components/FileAPI.js';\nimport CcSelectBox from '../../../components/select-box/ccSelectBox.vue';\nimport CcRadio from '../../../components/radio/ccRadio.vue';\nexport default {\n    props: {\n        value:{\n            type: [String,Boolean],\n            default: false\n        },\n        fileName: {\n            type: String,\n            default: null\n        },\n        size: {\n            type: String,\n            default: null\n        },\n        listFolder: {\n            type: Array,\n            default: () => []\n        },\n        organizationUnitID: {\n            type: Number,\n            default: null\n        },\n        organizationUnitName: {\n            type: String,\n            default: null\n        }\n    },\n    data(){\n        return{\n            loading: false,\n            optionFiles: [\"Tải lên\", \"Cá nhân\"],\n            optionValue: \"Tải lên\",\n            file: {\n                FileName: null,\n                Note: null,\n                TypeFile: \"Folder\",\n                TenantID: null,\n                CreatedBy: null,\n                Size: null,\n                OrganizationUnitID: null,\n                OrganizationUnitName: null,\n                NoteOrganizationUnit: null\n            },\n            fileResponse: null,\n            listFile: [],\n            dataSource: []\n        }\n    },\n    created(){\n        this.getFilePersonal();\n    },\n    methods: {\n        selectedFile(val){\n            this.file = val;\n        },\n        selectOrg(val){\n            this.organizationUnitID = val.OrganizationUnitID;\n            this.organizationUnitName = val.OrganizationUnitName;\n        },\n        uploadChoseFile(){\n            this.$refs.file.click();\n        },\n        choseFile(event){\n            let fd = new FormData();\n            fd.append('file',event.target.files[0])\n            let me = this;\n            FileAPI.UploadFile(fd).then(res => {\n                if(res.data && res.data.Success){\n                    me.file = res.data.Data;\n                }\n            }).catch(e => {});\n        },\n        close(){\n            this.$emit(\"input\",false);\n        },\n        uploadFile(){\n            var me = this;\n            this.file.TenantID = this.$store.getters.tenantID;\n            this.file.CreatedBy = this.$store.getters.employeeID;\n            this.loading = true;\n            if(this.optionValue == \"Tải lên\"){\n                this.file.OrganizationUnitID = this.organizationUnitID;\n                this.file.OrganizationUnitName = this.organizationUnitName;\n                FileAPI.Insert(this.file).then(res => {\n                    me.loading = false;\n                    if(res.data && res.data.Success){\n                        me.$emit(\"save\",true);\n                    }\n                });\n            }\n            else{\n               this.file.OrganizationUnitID = this.organizationUnitID;\n               this.file.OrganizationUnitName = this.organizationUnitName;\n                FileAPI.Update(this.file).then(res => {\n                    me.loading = false;\n                    if(res.data && res.data.Success){\n                        me.$emit(\"save\",true);\n                    }\n                });\n            }\n        },\n        getFilePersonal(){\n            var me = this;\n            let param = {\n                TenantID: this.$store.getters.tenantID,\n                EmployeeID: this.$store.getters.employeeID,\n            }\n            FileAPI.GetPersonal(param).then(res => {\n                if(res.data && res.data.Success){\n                    me.dataSource = res.data.Data;\n                    me.listFile = me.dataSource.filter(x => x.TypeFile != \"Folder\");\n                }\n            });\n        }\n    }\n}\n</script>\n<style lang=\"scss\" scoped>\n@import '@/styles/var-color.scss';\n.chose-file{\n    height: 300px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n.footer{\n    float: right;\n}\n.btn-chose{\n    width: 100%;\n    height: 36px;\n    border: 1px solid #dddddd;\n    border-radius: 4px;\n    padding: 0px 16px;\n    outline: none;\n    color: #9a9a9a;\n    text-align: left;\n    &:active{\n        border: 1px solid $primary-hover;\n    }\n}\n</style>"],"mappings":";;AAsDA,OAAAA,OAAA;AACA,OAAAC,WAAA;AACA,OAAAC,OAAA;AACA;EACAC,KAAA;IACAC,KAAA;MACAC,IAAA,GAAAC,MAAA,EAAAC,OAAA;MACAC,OAAA;IACA;IACAC,QAAA;MACAJ,IAAA,EAAAC,MAAA;MACAE,OAAA;IACA;IACAE,IAAA;MACAL,IAAA,EAAAC,MAAA;MACAE,OAAA;IACA;IACAG,UAAA;MACAN,IAAA,EAAAO,KAAA;MACAJ,OAAA,EAAAA,CAAA;IACA;IACAK,kBAAA;MACAR,IAAA,EAAAS,MAAA;MACAN,OAAA;IACA;IACAO,oBAAA;MACAV,IAAA,EAAAC,MAAA;MACAE,OAAA;IACA;EACA;EACAQ,KAAA;IACA;MACAC,OAAA;MACAC,WAAA;MACAC,WAAA;MACAC,IAAA;QACAC,QAAA;QACAC,IAAA;QACAC,QAAA;QACAC,QAAA;QACAC,SAAA;QACAC,IAAA;QACAC,kBAAA;QACAC,oBAAA;QACAC,oBAAA;MACA;MACAC,YAAA;MACAC,QAAA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,eAAA;EACA;EACAC,OAAA;IACAC,aAAAC,GAAA;MACA,KAAAjB,IAAA,GAAAiB,GAAA;IACA;IACAC,UAAAD,GAAA;MACA,KAAAxB,kBAAA,GAAAwB,GAAA,CAAAV,kBAAA;MACA,KAAAZ,oBAAA,GAAAsB,GAAA,CAAAT,oBAAA;IACA;IACAW,gBAAA;MACA,KAAAC,KAAA,CAAApB,IAAA,CAAAqB,KAAA;IACA;IACAC,UAAAC,KAAA;MACA,IAAAC,EAAA,OAAAC,QAAA;MACAD,EAAA,CAAAE,MAAA,SAAAH,KAAA,CAAAI,MAAA,CAAAC,KAAA;MACA,IAAAC,EAAA;MACAjD,OAAA,CAAAkD,UAAA,CAAAN,EAAA,EAAAO,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAApC,IAAA,IAAAoC,GAAA,CAAApC,IAAA,CAAAqC,OAAA;UACAJ,EAAA,CAAA7B,IAAA,GAAAgC,GAAA,CAAApC,IAAA,CAAAsC,IAAA;QACA;MACA,GAAAC,KAAA,CAAAC,CAAA;IACA;IACAC,MAAA;MACA,KAAAC,KAAA;IACA;IACAC,WAAA;MACA,IAAAV,EAAA;MACA,KAAA7B,IAAA,CAAAI,QAAA,QAAAoC,MAAA,CAAAC,OAAA,CAAAC,QAAA;MACA,KAAA1C,IAAA,CAAAK,SAAA,QAAAmC,MAAA,CAAAC,OAAA,CAAAE,UAAA;MACA,KAAA9C,OAAA;MACA,SAAAE,WAAA;QACA,KAAAC,IAAA,CAAAO,kBAAA,QAAAd,kBAAA;QACA,KAAAO,IAAA,CAAAQ,oBAAA,