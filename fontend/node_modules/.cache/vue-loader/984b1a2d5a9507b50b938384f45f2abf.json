n                    return item.Value;\n                }\n                return false;\n            }\n    // Nếu không có danh sách quyền, trả về false\n    console.log('Found Permission:', item);\n\n    return false;\n}\n    }\n}\n</script>\n<style lang=\"scss\" scoped>\n\n</style>"]}]}